# ============================================================================
# Lux Backend API — Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values.
# .env and .env.*.local are gitignored. This file (.env.example) is tracked.
# ============================================================================

# -- Admin Authentication ----------------------------------------------------
# Shared secret between frontend and backend. Frontend sends this in
# x-admin-token header for all ADMIN_ONLY routes (tts, pronunciation-gpt,
# evaluate, assess, convo-turn, convo-report, alt-meaning,
# realtime/webrtc/session, voice-clone, voice-mirror).
ADMIN_TOKEN=your-admin-token-here

# Secret that authorizes the Vercel daily cron hitting
# GET /api/admin/expenses/refresh. When set, Vercel automatically sends it as
# "Authorization: Bearer <CRON_SECRET>" on scheduled invocations. Without it the
# cron cannot authenticate (the button still works via the admin token).
CRON_SECRET=your-cron-secret-here

# -- Azure Speech Services ---------------------------------------------------
# Pronunciation assessment + TTS. Region is typically "eastus".
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus
# Alternative alias some code paths check:
# AZURE_REGION=eastus
# AZURE_TTS_KEY=your-azure-speech-key

# -- OpenAI ------------------------------------------------------------------
# Used for AI coaching, convo turns, reports, translation, alt-meaning.
OPENAI_API_KEY=sk-your-openai-key-here

# Org Admin key for the expense dashboard's OpenAI cost fetcher (organization
# Costs API). Mint at platform.openai.com/settings/organization/admin-keys.
# Optional: if unset, the OpenAI source falls back to manual on each refresh.
OPENAI_ADMIN_KEY=sk-admin-your-org-admin-key-here

# Model selection (all optional -- code has defaults):
# LUX_AI_QUICK_MODEL=gpt-4.1-mini
# LUX_AI_DEEP_MODEL=gpt-4.1
# LUX_AI_CONVO_MODEL=gpt-4.1-mini
# LUX_AI_REPORT_MODEL=gpt-4.1
# LUX_AI_TRANSLATE_MODEL=gpt-4.1-mini
# LUX_AI_DEEP_REASONING_MODEL=
# LUX_AI_DEEP_REASONING_EFFORT=medium
# LUX_AI_MODEL=gpt-4.1-mini

# -- Supabase (DB + Auth) ----------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Aliases accepted (any of these work):
# SUPABASE_SERVICE_ROLE=your-service-role-key
# SUPABASE_SERVICE_ROLE_KEY_JWT=your-jwt
# SUPABASE_SERVICE_KEY=your-service-key
# SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -- Postgres Connection -----------------------------------------------------
# Used by lib/pool.js. Any of these three names work.
POSTGRES_URL=postgresql://user:pass@host:5432/dbname
# POSTGRES_CONNECTION=postgresql://user:pass@host:5432/dbname
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Set to "disable" to skip SSL (local dev only):
# PGSSLMODE=

# -- ElevenLabs (Voice Mirror) -----------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-key

# -- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins. Empty = block all cross-origin.
CORS_ORIGINS=http://localhost:3000,https://luxurylanguagelearninglab.com

# -- Feature Flags -----------------------------------------------------------
# Enable Azure prosody analysis (costs more per request):
ENABLE_PROSODY=false
